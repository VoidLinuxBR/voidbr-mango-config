{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,

  "modules-left": ["sway/workspaces", "sway/mode"],

  "modules-center": ["clock"],

  "modules-right": [
    "custom/help",
    "pulseaudio",
    "cpu",
    "memory",
    "battery",
    "network",
    "tray"
  ],

  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

  "clock": {
    "format": "ΎΒ│ {:%d/%m/%Y  ΎΑΩ %H:%M}",
    "tooltip-format": "{:%A, %d/%m/%Y}"
  },

  "custom/help": {
    "format": "≤░αξ Help",
    "tooltip": true,
    "tooltip-format": "VoidBR Shortcuts\nClique ou pressione Super+F1",
    "on-click": "voidbr-mango-shortcuts"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "≤░ζθ Mutado",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%",
    "tooltip": true
  },

  "network": {
    "format-wifi": "ΎΘτ {essid}",
    "format-ethernet": "≤░ΙΑ Ethernet",
    "format-disconnected": "≤░Ψς Offline"
  },

  "cpu": {
    "format": "ΎΜδ {usage}%",
    "on-click": "gnome-system-monitor"
  },

  "memory": {
    "format": "≤░Ξδ {}%",
    "on-click": "foot -e htop"
  },

  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
